{
  manifest_version: "0.1.0",
  program: {
    image: "tenalirama2026/cybergym-agentx:v4",
    entrypoint: ["/app/cybergym_agentx"],
    env: {
      ANTHROPIC_API_KEY: "${config.anthropic_api_key}",
      NVIDIA_API_KEY: "${config.nvidia_api_key}",
      PORT: "9010",
    },
    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9010 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      anthropic_api_key: { type: "string", secret: true },
      nvidia_api_key: { type: "string", secret: true },
    },
    required: ["anthropic_api_key", "nvidia_api_key"],
    additionalProperties: false,
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },
  exports: {
    a2a: "a2a",
  },
}
