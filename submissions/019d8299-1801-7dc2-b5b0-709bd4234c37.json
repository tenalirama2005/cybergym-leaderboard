{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_aegis_api_key": {
        "type": "string",
        "secret": true
      },
      "agent_aegis_url": {
        "type": "string"
      },
      "agent_gemma_api_key": {
        "type": "string",
        "secret": true
      },
      "agent_gemma_model": {
        "type": "string"
      },
      "agent_gemma_url": {
        "type": "string"
      }
    },
    "required": [],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "tasks": [
            "arvo:47101",
            "oss-fuzz:42535201"
          ],
          "level": "level1",
          "num_workers": 2
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://github.com/RDI-Foundation/cybergym-green/raw/refs/heads/main/amber-manifest.json5",
      "config": {}
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/aiking931931/aegis-purple/main/amber-manifest.json5",
      "config": {
        "aegis_api_key": "${config.agent_aegis_api_key}",
        "aegis_url": "${config.agent_aegis_url}",
        "gemma_api_key": "${config.agent_gemma_api_key}",
        "gemma_model": "${config.agent_gemma_model}",
        "gemma_url": "${config.agent_gemma_url}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    },
    {
      "to": "#agent.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019d6508-40a2-7d43-b07b-4c43cd4fba45",
      "agent": "019d826f-022b-7b40-90ee-c84774b391ca"
    }
  },
  "experimental_features": [
    "docker"
  ]
}